{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Module System (Bundler mode – without extension requirement)
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "types": [],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,

    // Style / Constraints (не заважають)
    "isolatedModules": true,
    "verbatimModuleSyntax": false,   // вимикаємо, бо з Bundler не потрібно
    "moduleDetection": "force",
    
    // Дозволяємо вивід навіть із помилками типів
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}